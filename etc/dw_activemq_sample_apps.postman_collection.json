    {
      "name": "Producer - Plain JMS Topic (fixedtopic:announcements)",
      "item": [
        {
          "name": "Post JSON to plain JMS topic",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"fixedtopic:announcements\",\n  \"sendToAllEventsQueue\": false,\n  \"format\": \"JSON_CURRENT\",\n  \"messageType\": \"SYSTEM_NOTICE\",\n  \"data\": {\n    \"message\": \"Scheduled maintenance at midnight\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/produce", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["produce"] }
          }
        }
      ]
    },
    {
      "name": "Producer - Regular Queue (queue:notifications)",
      "item": [
        {
          "name": "Post a single notification",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"queue:notifications\",\n  \"sendToAllEventsQueue\": false,\n  \"format\": \"JSON_CURRENT\",\n  \"messageType\": \"USER_NOTIFICATION\",\n  \"data\": {\n    \"userId\": \"42\",\n    \"message\": \"Your order has shipped\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/produce", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["produce"] }
          }
        },
        {
          "name": "Post multiple notifications to observe competing consumer behavior",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"queue:notifications\",\n  \"sendToAllEventsQueue\": false,\n  \"count\": 10,\n  \"format\": \"JSON_CURRENT\",\n  \"messageType\": \"USER_NOTIFICATION\",\n  \"data\": {\n    \"userId\": \"42\",\n    \"message\": \"Your order has shipped\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/produce", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["produce"] }
          }
        }
      ]
    },
    {
      "name": "Producer - DLQ Testing (queue:poison_pill)",
      "item": [
        {
          "name": "Post to poison pill queue",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"queue:poison_pill\",\n  \"sendToAllEventsQueue\": false,\n  \"format\": \"TEXT\",\n  \"data\": \"this will expire\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/produce", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["produce"] }
          }
        }
      ]
    },
    {
      "name": "Consumer Alpha-1 - Received Messages (port 8081)",
      "item": [
        {
          "name": "Get all messages",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8081/received", "protocol": "http", "host": ["localhost"], "port": "8081", "path": ["received"] }
          }
        },
        {
          "name": "Get messages filtered by topic:orders",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8081/received?destination=topic:orders", "protocol": "http", "host": ["localhost"], "port": "8081", "path": ["received"], "query": [{ "key": "destination", "value": "topic:orders" }] }
          }
        },
        {
          "name": "Get messages filtered by fixedtopic:announcements",
          "request": {
            "method": "GET",
            "url": { "raw": "http://localhost:8081/received?destination=fixedtopic:announcements", "protocol": "http", "host": ["localhost"], "port": "8081", "path": ["received"], "query": [{ "key": "destination", "value": "fixedtopic:announcements" }] }
          }
        },
        {
          "name": "Clear messages",
          "request": {
            "method": "DELETE",
            "url": { "raw": "http://localhost:8081/received", "protocol": "http", "host": ["localhost"], "port": "8081", "path": ["received"] }
          }
        }
      ]
    },
