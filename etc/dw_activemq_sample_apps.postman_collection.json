{
  "info": {
    "name": "Dropwizard ActiveMQ Sample Apps",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Producer - Virtual Topic (topic:orders)",
      "item": [
        {
          "name": "Post JSON (current format) - sendToAllEventsQueue: true",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"topic:orders\",\n  \"sendToAllEventsQueue\": true,\n  \"format\": \"JSON_CURRENT\",\n  \"messageType\": \"ORDER_PLACED\",\n  \"data\": {\n    \"orderId\": \"123\",\n    \"total\": 49.99\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/produce", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["produce"] }
          }
        },
        {
          "name": "Post JSON (legacy format) - sendToAllEventsQueue: true",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"topic:orders\",\n  \"sendToAllEventsQueue\": true,\n  \"format\": \"JSON_LEGACY\",\n  \"messageType\": \"ORDER_PLACED\",\n  \"data\": {\n    \"orderId\": \"456\",\n    \"total\": 19.99\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/produce", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["produce"] }
          }
        },
        {
          "name": "Post JSON (echoed current format)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"topic:orders\",\n  \"sendToAllEventsQueue\": false,\n  \"format\": \"JSON_ECHOED_CURRENT\",\n  \"messageType\": \"ORDER_PLACED\",\n  \"data\": {\n    \"orderId\": \"789\",\n    \"total\": 99.99\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/produce", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["produce"] }
          }
        },
        {
          "name": "Post JSON (echoed legacy format)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"topic:orders\",\n  \"sendToAllEventsQueue\": false,\n  \"format\": \"JSON_ECHOED_LEGACY\",\n  \"messageType\": \"ORDER_PLACED\",\n  \"data\": {\n    \"orderId\": \"101\",\n    \"total\": 9.99\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/produce", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["produce"] }
          }
        },
        {
          "name": "Post XML",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"topic:orders\",\n  \"sendToAllEventsQueue\": false,\n  \"format\": \"XML\",\n  \"data\": \"<order><id>123</id></order>\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/produce", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["produce"] }
          }
        },
        {
          "name": "Post TEXT",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"topic:orders\",\n  \"sendToAllEventsQueue\": false,\n  \"format\": \"TEXT\",\n  \"data\": \"plain text order message\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/produce", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["produce"] }
          }
        },
        {
          "name": "Post BYTES",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"topic:orders\",\n  \"sendToAllEventsQueue\": false,\n  \"format\": \"BYTES\",\n  \"data\": \"bytes order message\"\n}",
              "options": { "raw": { "language": "json" } }
