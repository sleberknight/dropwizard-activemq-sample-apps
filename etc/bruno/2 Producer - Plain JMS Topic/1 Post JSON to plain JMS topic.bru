meta {
  name: Post JSON to plain JMS topic
  type: http
  seq: 1
}

post {
  url: http://localhost:8080/produce
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "destination": "fixedtopic:announcements",
    "sendToAllEventsQueue": false,
    "format": "JSON_CURRENT",
    "messageType": "SYSTEM_NOTICE",
    "data": {
      "message": "Scheduled maintenance at midnight"
    }
  }
}
