meta {
  name: Post MapMessage (triggers UnknownMessageTypeException)
  type: http
  seq: 3
}

post {
  url: http://localhost:8080/produce
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "destination": "queue:notifications",
    "format": "MAP_MESSAGE",
    "data": {
      "userId": "42",
      "message": "sent as a MapMessage"
    }
  }
}
