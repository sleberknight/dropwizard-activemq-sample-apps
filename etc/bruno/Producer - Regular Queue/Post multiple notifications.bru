meta {
  name: Post multiple notifications to observe competing consumer behavior
  type: http
  seq: 2
}

post {
  url: http://localhost:8080/produce
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "destination": "queue:notifications",
    "sendToAllEventsQueue": false,
    "count": 10,
    "format": "JSON_CURRENT",
    "messageType": "USER_NOTIFICATION",
    "data": {
      "userId": "42",
      "message": "Your order has shipped"
    }
  }
}
